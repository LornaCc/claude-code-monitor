<Window x:Class="CCMonitor.App.ConfirmRemoveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remove Session"
        Width="360"
        Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF7ED">
    <Border Margin="18" Padding="14" CornerRadius="10" Background="#FFFBEB" BorderBrush="#FED7AA" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Remove this session?" FontSize="18" FontWeight="SemiBold" Foreground="#431407" />
            <TextBlock x:Name="SessionText" Margin="0,12,0,0" Foreground="#9A3412" TextWrapping="Wrap" />
            <TextBlock Text="Claude Code will keep running, but CC Monitor will stop tracking this session." Margin="0,10,0,0" Foreground="#9A3412" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Cancel" Width="82" Height="30" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="Remove" Width="82" Height="30" Click="Remove_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
