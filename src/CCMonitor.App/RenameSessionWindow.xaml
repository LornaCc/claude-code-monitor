<Window x:Class="CCMonitor.App.RenameSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Name"
        Width="320"
        Height="170"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF7ED">
    <Border Margin="18">
        <StackPanel>
            <TextBlock Text="Session name" FontWeight="SemiBold" Foreground="#431407" Margin="0,0,0,8" />
            <TextBox x:Name="NameBox" Height="30" VerticalContentAlignment="Center" MaxLength="60" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Cancel" Width="78" Height="30" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="Save" Width="78" Height="30" Click="Save_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
