<Window x:Class="CCMonitor.App.UsageDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Usage Dashboard"
        Width="520"
        Height="560"
        MinWidth="420"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="#FFF7ED">
    <Grid Margin="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel>
                <TextBlock Text="Usage Dashboard" FontSize="22" FontWeight="SemiBold" Foreground="#431407" />
                <TextBlock Text="Session token usage" Foreground="#9A3412" Margin="0,6,0,12" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Sessions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Padding="12" Margin="0,0,0,10" Background="#FFFBEB" BorderBrush="#FED7AA" BorderThickness="1">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold" Foreground="#431407" />
                                        <TextBlock Text="{Binding Status}" DockPanel.Dock="Right" Foreground="#0F766E" FontWeight="SemiBold" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding ProjectName}" Foreground="#9A3412" FontSize="12" Margin="0,4,0,10" />
                                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                                        <TextBlock Text="Tokens" Foreground="#431407" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ModelText}" DockPanel.Dock="Right" Foreground="#0F766E" FontSize="11" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding TokenText}" Foreground="#9A3412" />
                                    <TextBlock Text="{Binding CostText}" Foreground="#0F766E" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding UpdatedText}" Foreground="#A16207" FontSize="11" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Refresh" Width="86" Height="32" Margin="0,0,8,0" Click="Refresh_Click" />
                <Button Content="Close" Width="86" Height="32" Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
