<Window x:Class="CCMonitor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="CC Monitor"
        Width="340"
        Height="260"
        MinWidth="280"
        MinHeight="180"
        MaxWidth="720"
        MaxHeight="720"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#FFF7ED"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="True">
    <Window.Resources>
        <Style x:Key="ActionIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFF7ED" />
            <Setter Property="Foreground" Value="#9A3412" />
            <Setter Property="BorderBrush" Value="#FED7AA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-3,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFEDD5" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FDBA74" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FED7AA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type primitives:Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
    <Border BorderBrush="#FDBA74" BorderThickness="1" CornerRadius="8" Background="#FFF7ED">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border Width="26" Height="26" CornerRadius="8" Background="#2DD4BF" Margin="12,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="CC" FontWeight="Bold" FontSize="10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CC Monitor" FontWeight="SemiBold" FontSize="14" Foreground="#431407" />
                    <TextBlock Text="Claude Code" FontSize="10" Foreground="#9A3412" />
                </StackPanel>
                <Button Content="&#x00D7;" Width="34" Height="30" Margin="0,8,8,8" Click="Close_Click" DockPanel.Dock="Right" ToolTip="Close" />
                <Button Content="&#x2212;" Width="34" Height="30" Margin="0,8,4,8" Click="Minimize_Click" DockPanel.Dock="Right" ToolTip="Minimize" />
                <Button Content="Settings" Width="70" Height="30" Margin="0,8,4,8" Click="Settings_Click" DockPanel.Dock="Right" />
                <Button Content="Usage" Width="58" Height="30" Margin="0,8,4,8" Click="Usage_Click" DockPanel.Dock="Right" />
                <Button Content="Refresh" Width="68" Height="30" Margin="0,8,4,8" Click="Refresh_Click" DockPanel.Dock="Right" />
                <Button x:Name="GroupButton" Content="Group" Width="58" Height="30" Margin="0,8,4,8" Click="GroupToggle_Click" DockPanel.Dock="Right" />
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="12,0,12,8">
                <StackPanel>
                    <ItemsControl x:Name="SessionsItems" ItemsSource="{Binding SessionsView}">
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <Expander IsExpanded="True" Margin="0,0,0,8">
                                                        <Expander.Header>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#7C2D12" />
                                                        </Expander.Header>
                                                        <ItemsPresenter />
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="CardBorder" CornerRadius="8" Padding="12" Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="SessionCard_MouseLeftButtonUp">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FFFBEB" />
                                        <Setter Property="BorderBrush" Value="#FED7AA" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNeedsAttention}" Value="True">
                                                <Setter Property="Background" Value="#FFF1F2" />
                                                <Setter Property="BorderBrush" Value="#FB7185" />
                                                <Setter Property="BorderThickness" Value="3" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsDoneFlashing}" Value="True">
                                                <Setter Property="Background" Value="#DCFCE7" />
                                                <Setter Property="BorderBrush" Value="#22C55E" />
                                                <Setter Property="BorderThickness" Value="2" />
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="4x" AutoReverse="True">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="1"
                                                                             To="0.62"
                                                                             Duration="0:0:0.35" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             To="1"
                                                                             Duration="0:0:0.1" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <DockPanel>
                                            <TextBlock Text="{Binding Dot}" Foreground="{Binding AccentBrush}" FontSize="18" Width="24" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding PrimaryText}" Foreground="#0F172A" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="#431407" FontSize="13" Margin="0,12,0,0" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding DetailText}" Foreground="#9A3412" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="&#x2026;" Style="{StaticResource ActionIconButtonStyle}" Margin="10,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Top" Click="OpenActionsMenu_Click">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Name" Click="RenameSession_Click" />
                                                    <MenuItem Header="Bind terminal…" Click="BindTerminal_Click" />
                                                    <MenuItem Header="Hide" Click="HideSession_Click" />
                                                    <Separator />
                                                    <MenuItem Header="Remove" Click="RemoveSession_Click" />
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Expander x:Name="HiddenExpander" Header="Hidden (0)" Visibility="Collapsed" Margin="0,4,0,0">
                        <StackPanel Margin="0,8,0,0">
                            <Button Content="Restore all" Height="28" Margin="0,0,0,8" Click="RestoreAllHidden_Click" />
                            <ItemsControl ItemsSource="{Binding HiddenSessions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="10" Margin="0,0,0,8" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="SessionCard_MouseLeftButtonUp">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding PrimaryText}" Foreground="#334155" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#334155" FontSize="12" Margin="0,8,0,0" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding DetailText}" Foreground="#64748B" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="&#x2026;" Style="{StaticResource ActionIconButtonStyle}" Margin="10,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Top" Click="OpenActionsMenu_Click">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Bind terminal…" Click="BindTerminal_Click" />
                                                                <MenuItem Header="Restore" Click="RestoreSession_Click" />
                                                                <Separator />
                                                                <MenuItem Header="Remove" Click="RemoveSession_Click" />
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                    </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" x:Name="IntegrationPanel" Margin="12,0,12,12">
                <TextBlock x:Name="EmptyText" Text="IDLE&#x0a;Waiting for task" FontSize="16" FontWeight="SemiBold" Foreground="#9A3412" TextAlignment="Center" Margin="0,18,0,22" Visibility="Collapsed" />
                <TextBlock x:Name="HooksStatusText" Foreground="#9A3412" FontSize="12" Margin="2,0,0,8" />
                <Button x:Name="InstallHooksButton" Content="Install Hooks" Height="32" Click="InstallHooks_Click" />
            </StackPanel>
        </Grid>
    </Border>
        <primitives:Thumb Height="6" VerticalAlignment="Top" Cursor="SizeNS" DragDelta="ResizeTop_DragDelta" />
        <primitives:Thumb Height="6" VerticalAlignment="Bottom" Cursor="SizeNS" DragDelta="ResizeBottom_DragDelta" />
        <primitives:Thumb Width="6" HorizontalAlignment="Left" Cursor="SizeWE" DragDelta="ResizeLeft_DragDelta" />
        <primitives:Thumb Width="6" HorizontalAlignment="Right" Cursor="SizeWE" DragDelta="ResizeRight_DragDelta" />
        <primitives:Thumb Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" DragDelta="ResizeTopLeft_DragDelta" />
        <primitives:Thumb Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" DragDelta="ResizeTopRight_DragDelta" />
        <primitives:Thumb Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" DragDelta="ResizeBottomLeft_DragDelta" />
        <primitives:Thumb Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="ResizeBottomRight_DragDelta" />
    </Grid>
</Window>
