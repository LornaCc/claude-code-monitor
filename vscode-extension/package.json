{
  "name": "cc-monitor-terminal-bridge",
  "displayName": "CC Monitor Terminal Bridge",
  "description": "Focuses the VS Code terminal associated with a CC Monitor session.",
  "version": "0.4.2",
  "publisher": "ccmonitor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LornaCc/claude-code-monitor.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:ccMonitor.focusTerminal",
    "onCommand:ccMonitor.createManagedClaudeTerminal",
    "onCommand:ccMonitor.migrateActiveTerminal",
    "onCommand:ccMonitor.bindActiveTerminalToSession"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ccMonitor.focusTerminal",
        "title": "CC Monitor: Focus Session Terminal"
      },
      {
        "command": "ccMonitor.createManagedClaudeTerminal",
        "title": "CC Monitor: Create Managed Claude Terminal"
      },
      {
        "command": "ccMonitor.migrateActiveTerminal",
        "title": "CC Monitor: Migrate Active Terminal"
      },
      {
        "command": "ccMonitor.bindActiveTerminalToSession",
        "title": "CC Monitor: Bind Active Terminal to Session"
      }
    ]
  },
  "scripts": {
    "package": "vsce package --no-dependencies",
    "test": "node --test terminal-matcher.test.js"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  }
}
